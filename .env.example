# Multi-Model Query Tool — API Key Fallback Configuration
# Copy to .env and fill in values for API key fallback support.
# These are ONLY used when the subscription CLI binary is unavailable.

# Anthropic (fallback for Claude Code CLI)
ANTHROPIC_API_KEY=

# OpenAI (fallback for Codex CLI)
OPENAI_API_KEY=

# Google (fallback for Gemini CLI)
GOOGLE_API_KEY=

# Perplexity (API-only — no CLI exists)
PERPLEXITY_API_KEY=

# AWS Bedrock (primary method — IAM-based)
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# Ollama (local — no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
